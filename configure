#!/bin/sh
# json2toon configure - a small handwritten configure script. It probes the
# toolchain and writes a make include file (default: config.mk; overridable via
# the CONFIGFILE environment variable, as the cross-build environments do).
#
# It deliberately performs no compile-and-RUN probes, so it works unchanged when
# cross-compiling (CROSS_COMPILING=yes), where target binaries cannot run on the
# build host. SIMD is selected from the compiler's own predefined target macros
# at compile time (see src/simd.c); this script only needs to honour
# --disable-simd and pick shared-library conventions for the target OS.

set -e

prefix=/usr/local
enable_simd=1
enable_debug=0
enable_shared=1
host=""

for arg in "$@"; do
  case "$arg" in
    --prefix=*)      prefix="${arg#*=}" ;;
    --host=*)        host="${arg#*=}" ;;
    --disable-simd)  enable_simd=0 ;;
    --enable-simd)   enable_simd=1 ;;
    --enable-debug)  enable_debug=1 ;;
    --disable-shared) enable_shared=0 ;;
    --enable-shared) enable_shared=1 ;;
    -h|--help)
      cat <<EOF
Usage: ./configure [OPTIONS]
  --prefix=DIR        installation root (default /usr/local)
  --host=TRIPLE       target triple when cross-compiling
  --disable-simd      build the scalar code path only
  --enable-debug      build with debug info and assertions
  --disable-shared    build the static library only
Environment: CC, AR, RANLIB, CFLAGS, LDFLAGS, CONFIGFILE are honoured.
EOF
      exit 0 ;;
    *) echo "configure: ignoring unknown option: $arg" >&2 ;;
  esac
done

CC="${CC:-cc}"
AR="${AR:-ar}"
RANLIB="${RANLIB:-ranlib}"
CONFIGFILE="${CONFIGFILE:-config.mk}"

# Determine the target OS for shared-library conventions. Prefer the explicit
# host triple (cross builds); otherwise fall back to the build host's uname.
target_os=""
case "$host" in
  *darwin*|*apple*) target_os=darwin ;;
  *linux*)          target_os=linux ;;
  *mingw*|*windows*) target_os=windows ;;
  "")               target_os="$(uname -s 2>/dev/null || echo unknown)" ;;
  *)                target_os=other ;;
esac
case "$target_os" in
  Darwin) target_os=darwin ;;
  Linux)  target_os=linux ;;
esac

case "$target_os" in
  darwin)
    SHLIB_EXT=dylib
    SHLIB_LDFLAGS="-dynamiclib -install_name $prefix/lib/libjson2toon.dylib" ;;
  windows)
    SHLIB_EXT=dll
    SHLIB_LDFLAGS="-shared" ;;
  *)
    SHLIB_EXT=so
    SHLIB_LDFLAGS="-shared -Wl,-soname,libjson2toon.so" ;;
esac

EXTRA_CFLAGS=""
if [ "$enable_simd" = "0" ]; then
  EXTRA_CFLAGS="$EXTRA_CFLAGS -DJ2T_DISABLE_SIMD"
  SIMD_DESC="disabled (scalar only)"
else
  SIMD_DESC="auto (from compiler target macros)"
fi

# In cross/static environments shared libraries are usually undesirable.
if [ -n "${STATIC_BUILD}" ] && [ "${STATIC_BUILD}" != "0" ]; then
  enable_shared=0
fi

DEBUG_DEFAULT=0
[ "$enable_debug" = "1" ] && DEBUG_DEFAULT=1

cat > "$CONFIGFILE" <<EOF
# Generated by ./configure -- do not edit.
CC = $CC
AR = $AR
RANLIB = $RANLIB
PREFIX = $prefix
EXTRA_CFLAGS = $EXTRA_CFLAGS
EXTRA_LDFLAGS =
SHLIB_EXT = $SHLIB_EXT
SHLIB_LDFLAGS = $SHLIB_LDFLAGS
ENABLE_SHARED = $enable_shared
DEBUG_DEFAULT = $DEBUG_DEFAULT
EOF

# pkg-config file.
if [ -f json2toon.pc.in ]; then
  sed -e "s#@PREFIX@#$prefix#g" \
      -e "s#@VERSION@#1.0.0#g" json2toon.pc.in > json2toon.pc
fi

echo "configure: writing $CONFIGFILE"
echo "  CC            = $CC"
echo "  prefix        = $prefix"
echo "  target os     = $target_os"
echo "  shared lib    = $enable_shared ($SHLIB_EXT)"
echo "  SIMD          = $SIMD_DESC"
